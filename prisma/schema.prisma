generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  role      String    @default("USER")
  articles  Article[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  articles Article[]
}

model Article {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  excerpt    String
  content    String
  image      String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  authorId   String
  categoryId String
  author     User     @relation(fields: [authorId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
}

model EVBrand {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logo      String?
  country   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models    EVModel[]
}

model EVModel {

  id        String   @id @default(cuid())

  name      String
  slug      String   @unique

  image     String?

  overview String?

  features String[]

  gallery String[]

  colors String[]

  pros String[]

  cons String[]

  exShowroomPrice Int?

  batteryKwh Float?

  claimedRange Int?

  realRange Int?

  powerHp Int?

  torqueNm Int?

  topSpeed Int?

  seating Int?

  bodyType String?

  driveType String?

  acCharging String?

  dcCharging String?

  bootSpace Int?

  groundClearance Int?

  warranty String?

  launchDate String?

  featured Boolean @default(false)

  brandId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  brand EVBrand @relation(fields: [brandId], references: [id])

  specs EVSpec[]
}

model EVSpec {

  id String @id @default(cuid())

  key String

  value String

  modelId String

  model EVModel @relation(fields:[modelId],references:[id])

}




generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////////

model User {

  id        String   @id @default(cuid())

  name      String

  email     String   @unique

  password  String

  role      String   @default("USER")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  articles  Article[]

}

//////////////////////////////////////////////////////////
// CATEGORY
//////////////////////////////////////////////////////////

model Category {

  id String @id @default(cuid())

  name String

  slug String @unique

  articles Article[]

}

//////////////////////////////////////////////////////////
// ARTICLE
//////////////////////////////////////////////////////////

model Article {

  id String @id @default(cuid())

  title String

  slug String @unique

  excerpt String

  tags String[]

  content String

  image String?

  published Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  authorId String

  categoryId String

  author User @relation(fields:[authorId],references:[id])

  category Category @relation(fields:[categoryId],references:[id])

}

//////////////////////////////////////////////////////////
// EV BRAND
//////////////////////////////////////////////////////////

model EVBrand {

  id String @id @default(cuid())

  name String @unique

  slug String @unique

  logo String?

  country String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  models EVModel[]

}

//////////////////////////////////////////////////////////
// EV MODEL
//////////////////////////////////////////////////////////

model EVModel {

  id String @id @default(cuid())

  name String

  slug String @unique

  image String?

  overview String?

  exShowroomPrice Int?

  batteryKwh Float?

  claimedRange Int?

  realRange Int?

  powerHp Int?

  torqueNm Int?

  topSpeed Int?

  seating Int?

  bodyType String?

  driveType String?

  acCharging String?

  dcCharging String?

  bootSpace Int?

  groundClearance Int?

  warranty String?

  launchDate String?

  featured Boolean @default(false)

  brandId String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt()

  brand EVBrand @relation(fields:[brandId],references:[id])

  status String @default("ACTIVE")

  specs EVSpec[]

  variants EVVariant[]

  gallery EVGallery[]

  colors EVColor[]

  features EVFeature[]

  pros EVPro[]

  cons EVCon[]

}

//////////////////////////////////////////////////////////
// EV SPECIFICATION
//////////////////////////////////////////////////////////

model EVSpec {

  id String @id @default(cuid())

  key String

  value String

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV VARIANT
//////////////////////////////////////////////////////////

model EVVariant {

  id String @id @default(cuid())

  name String

  price Int

  battery String?

  range String?

  power String?

  torque String?

  recommended Boolean @default(false)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV GALLERY
//////////////////////////////////////////////////////////

model EVGallery {

  id String @id @default(cuid())

  image String

  alt String?

  title String?

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV COLOR
//////////////////////////////////////////////////////////

model EVColor {

  id String @id @default(cuid())

  name String

  hexCode String?

  image String?

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV FEATURE
//////////////////////////////////////////////////////////

model EVFeature {

  id String @id @default(cuid())

  name String

  icon String?

  category String?

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV PROS
//////////////////////////////////////////////////////////

model EVPro {

  id String @id @default(cuid())

  text String

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV CONS
//////////////////////////////////////////////////////////

model EVCon {

  id String @id @default(cuid())

  text String

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV REVIEW
//////////////////////////////////////////////////////////

model EVReview {

  id String @id @default(cuid())

  overallRating Float?

  rangeScore Float?

  performanceScore Float?

  featureScore Float?

  comfortScore Float?

  safetyScore Float?

  valueScore Float?

  verdict String?

  modelId String @unique

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV FAQ
//////////////////////////////////////////////////////////

model EVFAQ {

  id String @id @default(cuid())

  question String

  answer String

  sortOrder Int @default(0)

  modelId String

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV CHARGING
//////////////////////////////////////////////////////////

model EVCharging {

  id String @id @default(cuid())

  chargerType String?

  acPower String?

  dcPower String?

  acTime String?

  dcTime String?

  chargingCostPer100Km Float?

  modelId String @unique

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}

//////////////////////////////////////////////////////////
// EV SAFETY
//////////////////////////////////////////////////////////

model EVSafety {

  id String @id @default(cuid())

  airbags Int?

  abs Boolean @default(true)

  esc Boolean @default(true)

  tractionControl Boolean @default(false)

  adasLevel String?

  ncapRating String?

  hillAssist Boolean @default(false)

  tpms Boolean @default(false)

  modelId String @unique

  model EVModel @relation(fields:[modelId],references:[id], onDelete: Cascade)

}